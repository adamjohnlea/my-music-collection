{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block styles %}
  <style>
    .help-layout { display: grid; grid-template-columns: 220px 1fr; gap: 32px; align-items: start; }
    .help-toc { position: sticky; top: 88px; }
    .help-toc ul { list-style: none; margin: 0; padding: 0; }
    .help-toc li { margin: 0 0 8px 0; }
    .help-toc a { color: var(--muted); text-decoration: none; font-size: 0.95rem; }
    .help-toc a:hover { color: var(--accent); }
    .help-section { background: var(--card); border-radius: 12px; padding: 24px; margin-bottom: 20px; scroll-margin-top: 88px; }
    .help-section h2 { margin: 0 0 8px 0; font-size: 1.4rem; color: var(--accent); }
    .help-section .lede { color: var(--muted); margin: 0 0 16px 0; }
    .help-section ol, .help-section ul { margin: 0 0 0 20px; padding: 0; }
    .help-section li { margin-bottom: 8px; }
    .help-shot { display: block; max-width: 100%; height: auto; border-radius: 8px; border: 1px solid var(--border); margin: 16px 0; }
    .help-tip { border-left: 3px solid var(--accent); background: var(--input-bg); padding: 12px 16px; border-radius: 6px; margin: 16px 0 0 0; }
    .help-tip strong { color: var(--accent); }
    @media (max-width: 768px) {
      .help-layout { grid-template-columns: 1fr; }
      .help-toc { position: static; top: auto; margin-bottom: 16px; }
    }
  </style>
{% endblock %}

{% block breadcrumbs %}
  <nav class="breadcrumbs">
    <div>
      <a href="{{ static_export ? (base_url is same as('') ? (depth > 0 ? '../' : './') ~ 'index.html' : base_url) : '/' }}">Home</a>
      <span>/</span>
      Help
    </div>
  </nav>
{% endblock %}

{% block content %}
  <div class="wrap content-wrap">
    <div class="help-layout">
      <aside class="help-toc">
        <ul>
          <li><a href="#getting-started">Getting Started</a></li>
          <li><a href="#browsing">Browsing your Collection</a></li>
          <li><a href="#searching">Searching</a></li>
          <li><a href="#smart-collections">Smart Collections</a></li>
          <li><a href="#release-detail">Release detail</a></li>
          <li><a href="#recommendations">AI Recommendations</a></li>
          <li><a href="#apple-music">Apple Music</a></li>
          <li><a href="#discogs-search">Live Discogs Search</a></li>
          <li><a href="#stats">Statistics</a></li>
          <li><a href="#surprise-me">Surprise Me</a></li>
          <li><a href="#valuation">Valuation</a></li>
          <li><a href="#tools">Tools</a></li>
          <li><a href="#theme">Theme</a></li>
          <li><a href="#static-export">Static Site Export</a></li>
        </ul>
      </aside>

      <div class="help-content">
        <section id="getting-started" class="help-section">
          <h2>Getting Started</h2>
          <p class="lede">Connect your Discogs account and pull in your collection.</p>
          <ol>
            <li>Copy <code>.env.example</code> to <code>.env</code>.</li>
            <li>Get a personal access token from your <a href="https://www.discogs.com/settings/developers" target="_blank" rel="noopener">Discogs developer settings</a> (click "Generate new token").</li>
            <li>Add <code>DISCOGS_USERNAME</code> and <code>DISCOGS_TOKEN</code> to <code>.env</code>.</li>
            <li>Open <a href="/tools">Tools</a> and click "Run initial sync" to import your Collection and Wantlist. Watch the progress stream in real time.</li>
          </ol>
          <div class="help-tip"><strong>Tip:</strong> That's all you need to start browsing. Enrichment (full tracklists/credits), cover images, and valuation are optional follow-ups you can run any time from Tools.</div>
        </section>

        <section id="browsing" class="help-section">
          <h2>Browsing your Collection</h2>
          <p class="lede">The collection grid is your home base — fast, local, and offline-friendly.</p>
          <img class="help-shot" src="{{ '/help-assets/collection.png' }}" alt="Collection grid filtered to artist:devo, showing cover art tiles">
          <ol>
            <li>Click any cover to open its release detail page.</li>
            <li>Click a cover image again on the release page to open the full-size lightbox gallery; use the arrows, dots, or swipe to page through additional photos.</li>
            <li>Use the sort dropdown above the grid to change order: Added (default), Year, Artist, Title, Rating, or Value.</li>
            <li>Toggle between Collection and Wantlist views from the header.</li>
          </ol>
        </section>

        <section id="searching" class="help-section">
          <h2>Searching</h2>
          <p class="lede">Full-text search across your whole collection, with field prefixes for precision.</p>
          <ol>
            <li>Type into the search box in the header — plain words search across artist, title, labels, formats, tracklist, credits, and notes.</li>
            <li>Use quotes for exact phrases, e.g. <code>artist:"duran duran"</code>.</li>
            <li>Target a field with a prefix, e.g. <code>artist:devo</code>, <code>year:1980..1989</code>, or <code>barcode:0602527</code>.</li>
            <li>Don't want to remember prefixes? Click <strong>Advanced</strong> next to the search box to open the query builder: pick a field, enter a value, click (+) to add it to your query.</li>
          </ol>
        </section>

        <section id="smart-collections" class="help-section">
          <h2>Smart Collections</h2>
          <p class="lede">Save a search once, reuse it forever from the sidebar.</p>
          <ol>
            <li>Run a search, e.g. <code>genre:jazz year:1950..1960 format:vinyl</code>.</li>
            <li>Click <strong>Save Search</strong> in the sidebar.</li>
            <li>It now appears as a shortcut in the sidebar and updates automatically as matching releases are added to your collection.</li>
            <li>To remove one, hover over it in the sidebar and click the × that appears, then confirm.</li>
          </ol>
        </section>

        <section id="release-detail" class="help-section">
          <h2>Release detail</h2>
          <p class="lede">Everything about one release: tracklist, credits, and your personal notes.</p>
          <img class="help-shot" src="{{ '/help-assets/release.png' }}" alt="Release detail page for a Devo record, showing a 5-star rating, condition, and notes">
          <ol>
            <li>Use the <strong>Tracks</strong>, <strong>Details</strong>, and <strong>Credits</strong> tabs to read the tracklist, formats/notes/videos/barcodes, and personnel/company credits.</li>
            <li>Open the <strong>Status &amp; Notes</strong> tab and click <strong>Edit</strong> to set your rating, media condition, and sleeve condition, or write a personal note. This is only available for releases already in your collection.</li>
            <li>Click <strong>Save Changes</strong> to queue the update locally.</li>
          </ol>
          <div class="help-tip"><strong>Tip:</strong> Saving here only updates your local database. Ratings and conditions are sent to Discogs the next time you run "Push Changes to Discogs" from Tools — personal notes stay local unless notes-pushing is explicitly enabled.</div>
        </section>

        <section id="recommendations" class="help-section">
          <h2>AI Recommendations</h2>
          <p class="lede">Discover similar artists and releases based on your own collection.</p>
          <ol>
            <li>Open any release page.</li>
            <li>Click the <strong>Recommendations</strong> tab.</li>
            <li>Claude suggests 5 similar artists or releases, informed by your top artists and genres. Each result has a <strong>Live Search</strong> link to jump straight to it on Discogs.</li>
          </ol>
          <div class="help-tip"><strong>Tip:</strong> Requires an <code>ANTHROPIC_API_KEY</code> in your <code>.env</code> file. The Recommendations tab only appears once a key is configured. Results are cached locally for 30 days.</div>
        </section>

        <section id="apple-music" class="help-section">
          <h2>Apple Music</h2>
          <p class="lede">Play an embedded Apple Music preview right on the release page.</p>
          <ol>
            <li>Open a release page and select the <strong>Tracks</strong> tab.</li>
            <li>If a match is found, an Apple Music player appears automatically below the tracklist.</li>
          </ol>
          <div class="help-tip"><strong>Tip (gotcha):</strong> Matching relies on the release's <strong>barcode</strong>, which is only populated after enrichment (<code>sync:enrich</code>). You'll also need an <code>APPLE_MUSIC_DEVELOPER_TOKEN</code> (a signed JWT from your Apple Music developer account) in <code>.env</code>. Without both, no player will appear.</div>
        </section>

        <section id="discogs-search" class="help-section">
          <h2>Live Discogs Search</h2>
          <p class="lede">Search the live Discogs database and add what you find straight to your library.</p>
          <ol>
            <li>Prefix your search with <code>discogs:</code>, e.g. <code>discogs: artist:devo type:master</code>, or use the live search button next to the search box.</li>
            <li>Review the results, which are fetched directly from Discogs (not your local database).</li>
            <li>Click a result's action button to add it to your Collection or Wantlist.</li>
          </ol>
        </section>

        <section id="stats" class="help-section">
          <h2>Statistics</h2>
          <p class="lede">Visualize the shape of your collection.</p>
          <img class="help-shot" src="{{ '/help-assets/stats.png' }}" alt="Statistics page with charts by artist, genre, decade, and format">
          <ol>
            <li>Open <strong>Stats</strong> from the navigation.</li>
            <li>Browse the breakdowns by artist, genre, decade, and format to see what your collection is made of.</li>
            <li>Check the value-over-time chart to see how your collection's estimated worth has changed across valuation runs.</li>
          </ol>
        </section>

        <section id="surprise-me" class="help-section">
          <h2>Surprise Me</h2>
          <p class="lede">Can't decide what to play? Let the app pick.</p>
          <ol>
            <li>Click <strong>Surprise Me</strong> in the navigation, from anywhere in the app.</li>
            <li>You'll land on a randomly chosen release from your collection.</li>
          </ol>
        </section>

        <section id="valuation" class="help-section">
          <h2>Valuation</h2>
          <p class="lede">Estimate what your collection is worth, priced at each record's actual condition.</p>
          <img class="help-shot" src="{{ '/help-assets/valuable.png' }}" alt="Most Valuable page listing releases sorted by estimated value">
          <ol>
            <li>Open <a href="/tools">Tools</a> and click <strong>Value Collection</strong> to price your Collection and/or Wantlist against Discogs marketplace data.</li>
            <li>Visit <strong>Most Valuable</strong> from the navigation to see releases sorted highest value first, or check the per-release value on any release's detail page.</li>
            <li>Back in Tools, click <strong>Export Insurance CSV</strong> to download a dated CSV manifest (Artist, Title, Condition, Value, Currency, Source) — equivalent to running <code>php bin/console value:export</code>.</li>
          </ol>
          <div class="help-tip"><strong>Tip (gotcha):</strong> Condition-matched pricing requires Discogs <strong>Seller Settings</strong> to be enabled on your account. Without it, valuation falls back to the lowest active marketplace listing instead of a price matched to your recorded condition.</div>
        </section>

        <section id="tools" class="help-section">
          <h2>Tools</h2>
          <p class="lede">Every sync, valuation, and maintenance command, run from your browser with live progress.</p>
          <img class="help-shot" src="{{ '/help-assets/tools.png' }}" alt="Tools page showing Intake, Value, Publish, and Maintenance command cards">
          <ol>
            <li>Open <strong>Tools</strong> from the navigation.</li>
            <li>Pick a card — Refresh, Enrich, Backfill Images, Initial Sync, Value Collection, Export Insurance CSV, Push Changes, Export Static Site, or Rebuild Search Index.</li>
            <li>Fill in any options (limits, scope, output path) and click the card's run button.</li>
            <li>Watch the output stream in real time in the console panel until it reports "Completed successfully."</li>
          </ol>
          <div class="help-tip"><strong>Tip (gotcha):</strong> Cover image downloads are throttled to roughly 1 request/second with a persisted cap of <strong>1000</strong> images per day. If you have a large collection, re-run "Backfill Images" on subsequent days to keep filling in the rest.</div>
        </section>

        <section id="theme" class="help-section">
          <h2>Theme</h2>
          <p class="lede">Recolor the whole app to your taste, with a live preview before you commit.</p>
          <img class="help-shot" src="{{ '/help-assets/theme.png' }}" alt="Theme page with color swatches, presets, and a live preview sampler">
          <ol>
            <li>Open <strong>Theme</strong> from the navigation.</li>
            <li>Toggle between <strong>Dark</strong> and <strong>Light</strong> mode.</li>
            <li>Pick a preset swatch, or edit individual colors using the pickers/hex fields — the live preview sampler updates as you go.</li>
            <li>Click <strong>Save</strong> to persist your theme. Nothing changes app-wide until you save.</li>
          </ol>
          <div class="help-tip"><strong>Tip:</strong> Your saved theme is baked into any static export you generate, so exported sites keep your look.</div>
        </section>

        <section id="static-export" class="help-section">
          <h2>Static Site Export</h2>
          <p class="lede">Generate a portable, standalone copy of your collection you can host anywhere.</p>
          <ol>
            <li>Run <code>php bin/console export:static</code> from the command line, or click <strong>Export Static Site</strong> on the <a href="/tools">Tools</a> page.</li>
            <li>Optionally set an output directory, base URL, chunk size, and whether to copy cached images alongside the export.</li>
            <li>Host the resulting <code>dist</code> folder anywhere that serves static files — no PHP or database required to view it.</li>
          </ol>
          <div class="help-tip"><strong>Tip:</strong> The export is read-only and portable. Tools, Theme, and this Help page are part of the live app only — they are not included in the static export.</div>
        </section>
      </div>
    </div>
  </div>
{% endblock %}
