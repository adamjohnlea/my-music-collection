{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block styles %}
  <style>
    .num{font-variant-numeric:tabular-nums}

    /* page head */
    .stats-head{margin:8px 0 22px}
    .kicker{font:600 .72rem/1 var(--mono);letter-spacing:.18em;text-transform:uppercase;
      color:var(--accent);display:inline-flex;align-items:center;gap:8px}
    .kicker::before{content:"";width:22px;height:1px;background:var(--accent);opacity:.6}
    .stats-head h1{font-size:2.1rem;line-height:1.1;letter-spacing:-.02em;margin:.3em 0 0}

    .card{background:var(--card);border:1px solid var(--border-soft);border-radius:12px;padding:18px}

    /* badge (shared vocabulary) */
    .badge{font:600 .66rem/1 var(--mono);letter-spacing:.05em;text-transform:uppercase;
      display:inline-flex;align-items:center;gap:6px;padding:5px 8px;border-radius:999px;
      border:1px solid var(--border-soft);color:var(--muted);white-space:nowrap}
    .badge .pip{width:6px;height:6px;border-radius:50%;background:currentColor}
    .badge.warn{color:var(--warn);border-color:color-mix(in srgb,var(--warn) 35%,transparent)}

    /* big-number cards */
    .stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:14px;margin-bottom:14px}
    .bignum .eye{font:600 .7rem/1 var(--mono);letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
    .bignum .n{font-size:2.3rem;font-weight:750;letter-spacing:-.02em;margin:12px 0 6px;font-variant-numeric:tabular-nums}
    .bignum .sub{font-size:.82rem;color:var(--faint);display:flex;align-items:center;gap:8px;flex-wrap:wrap}

    /* value over time */
    .voc{margin-bottom:14px}
    .voc .eye{font:600 .7rem/1 var(--mono);letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin:0 0 12px}
    .voc .top{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:6px;flex-wrap:wrap}
    .voc .cur{font-size:2rem;font-weight:750;letter-spacing:-.02em;font-variant-numeric:tabular-nums}
    .voc .rhs{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
    .chip{font:600 .78rem var(--mono);display:inline-flex;align-items:center;gap:5px;padding:5px 9px;border-radius:8px;
      font-variant-numeric:tabular-nums}
    .chip.up{color:var(--up);background:color-mix(in srgb,var(--up) 13%,transparent)}
    .chip.down{color:var(--down);background:color-mix(in srgb,var(--down) 13%,transparent)}
    .chip.flat{color:var(--muted);background:color-mix(in srgb,var(--muted) 13%,transparent)}
    .voc-since{color:var(--faint);font:500 .8rem var(--mono)}
    .voc svg{display:block;width:100%;height:auto;margin-top:2px}
    .voc-axis{display:flex;justify-content:space-between;font:500 .72rem var(--mono);color:var(--faint);margin-top:4px}
    .voc-empty{color:var(--muted);margin:0}

    /* bar-chart cards */
    .two{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .card-title{margin:0 0 14px;font-size:1rem;font-weight:700;letter-spacing:-.01em}
    .brow{display:grid;grid-template-columns:130px 1fr 46px;align-items:center;gap:12px;padding:6px 0}
    .brow .lab{font-size:.86rem;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .brow .track{height:8px;border-radius:999px;background:var(--input-bg);overflow:hidden}
    .brow .fill{display:block;height:100%;border-radius:999px;
      background:linear-gradient(90deg,color-mix(in srgb,var(--accent) 55%,transparent),var(--accent))}
    .brow .ct{font:600 .82rem var(--mono);color:var(--muted);text-align:right;font-variant-numeric:tabular-nums}

    @media (max-width:820px){ .two{grid-template-columns:1fr} .stats-head h1{font-size:1.75rem} }
  </style>
{% endblock %}

{% block breadcrumbs %}
  <nav class="breadcrumbs">
    <div>
      <a href="{{ static_export ? (base_url is same as('') ? (depth > 0 ? '../' : './') ~ 'index.html' : base_url) : '/' }}">Home</a>
      <span>/</span>
      Stats
    </div>
  </nav>
{% endblock %}

{% block content %}
  <div class="wrap content-wrap">
    <div class="stats-head">
      <span class="kicker">Statistics</span>
      <h1>{{ title }}</h1>
    </div>

    <!-- big numbers -->
    <div class="stat-grid">
      <div class="card bignum">
        <div class="eye">Total releases</div>
        <div class="n">{{ total_count|number_format }}</div>
        <div class="sub">across your collection</div>
      </div>

      <div class="card bignum">
        <div class="eye">Collection value</div>
        <div class="n">{{ collection_currency|currency_symbol }}{{ collection_value|number_format(2) }}</div>
        <div class="sub">
          {% if collection_items is defined %}
            <span class="num">{{ collection_valued|number_format }} of {{ collection_items|number_format }} valued</span>
            {% if collection_assumed > 0 %}
              <span class="badge warn"><span class="pip"></span>{{ collection_assumed|number_format }} assumed grade</span>
            {% endif %}
          {% else %}
            {{ collection_coverage }}
          {% endif %}
        </div>
      </div>

      <div class="card bignum">
        <div class="eye">Wantlist · cost to complete</div>
        <div class="n">{{ collection_currency|currency_symbol }}{{ wantlist_value|number_format(2) }}</div>
        <div class="sub">to own everything on your list</div>
      </div>
    </div>

    <!-- value over time -->
    {% if value_chart is defined and value_chart.state != 'empty' %}
      <div class="card voc">
        <div class="eye">Value over time</div>
        <div class="top">
          <span class="cur">{{ collection_currency|currency_symbol }}{{ value_chart.current.value|number_format(2) }}</span>
          {% if value_chart.state == 'series' %}
            {% set prefix = value_chart.direction == 'down' ? '−' : (value_chart.direction == 'up' ? '+' : '') %}
            <span class="rhs">
              <span class="chip {{ value_chart.direction }}">
                {% if value_chart.direction == 'up' %}<span aria-hidden="true">▲</span>{% elseif value_chart.direction == 'down' %}<span aria-hidden="true">▼</span>{% endif %}
                {{ prefix }}{{ collection_currency|currency_symbol }}{{ (value_chart.deltaAbs|abs)|number_format(2) }}{% if value_chart.deltaPct is not null %} · {{ prefix }}{{ (value_chart.deltaPct|abs)|number_format(1) }}%{% endif %}
              </span>
              <span class="voc-since">since {{ value_chart.start.date }}</span>
            </span>
          {% endif %}
        </div>

        {% if value_chart.state == 'series' %}
          <svg viewBox="0 0 600 160" role="img"
               aria-label="Collection value from {{ collection_currency|currency_symbol }}{{ value_chart.start.value|number_format(2) }} on {{ value_chart.start.date }} to {{ collection_currency|currency_symbol }}{{ value_chart.current.value|number_format(2) }} on {{ value_chart.current.date }}">
            <defs>
              <linearGradient id="vocFill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.28"/>
                <stop offset="100%" stop-color="var(--accent)" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <polygon fill="url(#vocFill)" points="{{ value_chart.areaPoints }}"></polygon>
            <polyline fill="none" stroke="var(--accent)" stroke-width="2.5"
                      stroke-linejoin="round" stroke-linecap="round" points="{{ value_chart.linePoints }}"></polyline>
            {% for dot in value_chart.dots %}
              {% if loop.last %}
                <circle cx="{{ dot.x }}" cy="{{ dot.y }}" r="9" fill="var(--accent)" opacity="0.18"></circle>
                <circle cx="{{ dot.x }}" cy="{{ dot.y }}" r="4.5" fill="var(--accent)"></circle>
              {% else %}
                <circle cx="{{ dot.x }}" cy="{{ dot.y }}" r="3" fill="var(--accent)"></circle>
              {% endif %}
            {% endfor %}
          </svg>
          <div class="voc-axis">
            <span>{{ value_chart.axis.startDate }}</span>
            <span>{{ value_chart.axis.currentDate }}</span>
          </div>
        {% else %}
          <p class="voc-empty">Tracking started {{ value_chart.start.date }} — your first change will appear after the next valuation.</p>
        {% endif %}
      </div>
    {% endif %}

    <!-- breakdowns -->
    <div class="two">
      <div class="card">
        <h2 class="card-title">Top Artists</h2>
        {% for a in top_artists %}
          <div class="brow">
            <span class="lab" title="{{ a.artist }}">{{ a.artist|strip_discogs_suffix }}</span>
            <span class="track"><span class="fill" style="width: {{ (a.count / top_artists[0].count * 100)|round }}%"></span></span>
            <span class="ct">{{ a.count|number_format }}</span>
          </div>
        {% endfor %}
      </div>

      <div class="card">
        <h2 class="card-title">Top Genres</h2>
        {% for g in top_genres %}
          <div class="brow">
            <span class="lab">{{ g.genre }}</span>
            <span class="track"><span class="fill" style="width: {{ (g.count / top_genres[0].count * 100)|round }}%"></span></span>
            <span class="ct">{{ g.count|number_format }}</span>
          </div>
        {% endfor %}
      </div>

      <div class="card">
        <h2 class="card-title">Decades</h2>
        {% set max_decade = 0 %}
        {% for d in decades %}{% if d.count > max_decade %}{% set max_decade = d.count %}{% endif %}{% endfor %}
        {% for d in decades %}
          <div class="brow">
            <span class="lab">{{ d.decade }}s</span>
            <span class="track"><span class="fill" style="width: {{ (d.count / max_decade * 100)|round }}%"></span></span>
            <span class="ct">{{ d.count|number_format }}</span>
          </div>
        {% endfor %}
      </div>

      <div class="card">
        <h2 class="card-title">Formats</h2>
        {% set max_format = 0 %}
        {% if formats %}{% set max_format = formats[0].count %}{% endif %}
        {% for f in formats %}
          <div class="brow">
            <span class="lab">{{ f.format_name }}</span>
            <span class="track"><span class="fill" style="width: {{ (f.count / max_format * 100)|round }}%"></span></span>
            <span class="ct">{{ f.count|number_format }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
{% endblock %}
