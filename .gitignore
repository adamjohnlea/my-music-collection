# Dependencies
/vendor/
/composer.phar

# Environment
.env
.env.local
.env.*.local

# OS / IDE
.DS_Store
.idea/
.vscode/
*.iml
.phpactor.json

# PHP caches/tools
.phpunit.result.cache
.phpunit.cache/
.php-cs-fixer.cache

# Coverage reports (regenerated on demand for mutation testing)
/var/coverage/
/infection.html

# Runtime / storage (SQLite DB, caches, logs)
/var/app.db
/var/*.db
/var/*.sqlite
/var/*.db-wal
/var/*.db-shm
/var/*.log
/var/cache/
/var/tmp/
/var/sessions/

# Image cache (keep the placeholder file tracked)
/public/images/*
!public/images/.gitkeep

# Prevent accidental DBs under web root
/public/var/
/public/*.db

# Stray SQLite file created when an in-memory DSN (":memory:") is treated as a path
/:memory:

# Swap files
*.swp
*.swo
# Local working status file (intentionally untracked)
/CURRENTSTATUS.md
/var/progress/

# Superpowers subagent-driven-development scratch
.superpowers/

# Generated valuation export manifests
var/valuation-*.csv

# Generated poster images
/var/posters/

# Node deps for one-off tooling scripts (e.g. bin/capture-help-screenshots.mjs)
/node_modules/
